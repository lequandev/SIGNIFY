{
  "manifest_version": 3,
  "name": "Signify - YouTube Sign Language Overlay",
  "version": "1.0.0",
  "description": "Translates YouTube subtitles into Sign Language animations using Gemini AI and custom vocabulary mapping.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://signify-g3zb.onrender.com/*",
    "https://signify-i3rd.onrender.com/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*",
    "*://*.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "wordDictionary.js", "vietnameseCompoundWords.json", "icons/logo.png"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://signify-i3rd.onrender.com/*", "http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["auth-sync.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
